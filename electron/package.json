{
  "name": "cosmodex-desktop",
  "productName": "Cosmodex",
  "version": "1.0.0",
  "description": "Cosmodex v2 as a native desktop app (Electron wrapper).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cosmodex.desktop",
    "productName": "Cosmodex",
    "files": ["main.js", "preload.js", "package.json"],
    "mac": { "category": "public.app-category.productivity", "target": ["dmg"] },
    "win": { "target": ["nsis"] }
  }
}
